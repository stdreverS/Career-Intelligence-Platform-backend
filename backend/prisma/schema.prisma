// Это описание нашей базы данных
// Prisma сама создаст все таблицы по этой схеме

generator client {
  provider = "prisma-client-js"
  binatyTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Таблица пользователей
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // хранится в зашифрованном виде (bcrypt)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // У одного пользователя может быть много сессий с ИИ
  sessions  ChatSession[]
  resumes   Resume[]
}

// Таблица сессий чата (память ИИ по пользователю)
model ChatSession {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("Новый анализ")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  resume    Resume?
}

// Таблица сообщений чата
model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // "user" или "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Таблица готовых резюме
model Resume {
  id              String   @id @default(uuid())
  userId          String
  sessionId       String   @unique
  targetPosition  String   // желаемая должность
  currentSalary   String?  // зарплата сейчас
  futureSalary    String?  // зарплата после обучения
  content         String   @db.Text // полный текст резюме в JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}